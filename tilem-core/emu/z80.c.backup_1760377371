// ARM64 OPTIMIZATION - Phase 2.2: Force inline to eliminate function call overhead
// ARM64 FIX (Oct 9, 2025 14:30 UTC): Process ALL expired timers, not just first one
static inline void __attribute__((always_inline)) check_timers(TilemCalc* calc)
{
	int tmr;
	dword t;
	TilemZ80TimerFunc callback;
	void* callbackdata;

	// ARM64 DEBUG: Log check_timers calls during HALT (first 10 times)
	static int check_timers_count = 0;
	int is_halt_call = (calc->z80.halted == 1);
	if (is_halt_call && check_timers_count < 10) {
		char buf[512];
		snprintf(buf, sizeof(buf),
			"*** CHECK_TIMERS[%d] ENTRY: clock=%u timer_cpu=%d timer_rt=%d halted=%d",
			check_timers_count, (unsigned)calc->z80.clock,
			calc->z80.timer_cpu, calc->z80.timer_rt, calc->z80.halted);
		tilem_qt_debug(buf);

		// Log details of first 3 timers in CPU list
		if (calc->z80.timer_cpu) {
			int t1 = calc->z80.timer_cpu;
			snprintf(buf, sizeof(buf),
				"  Timer[%d]: count=%u period=%u (expires in %d cycles)",
				t1, (unsigned)calc->z80.timers[t1].count,
				(unsigned)calc->z80.timers[t1].period,
				(int)(calc->z80.timers[t1].count - calc->z80.clock));
			tilem_qt_debug(buf);

			if (calc->z80.timers[t1].next) {
				int t2 = calc->z80.timers[t1].next;
				snprintf(buf, sizeof(buf),
					"  Timer[%d]: count=%u period=%u (expires in %d cycles)",
					t2, (unsigned)calc->z80.timers[t2].count,
					(unsigned)calc->z80.timers[t2].period,
					(int)(calc->z80.timers[t2].count - calc->z80.clock));
				tilem_qt_debug(buf);
			}
		}
	}

	// Process CPU timers - loop until we find one that hasn't expired
	int cpu_timers_processed = 0;
	while (calc->z80.timer_cpu) {
		tmr = calc->z80.timer_cpu;
		t = calc->z80.clock - calc->z80.timers[tmr].count;

		// ARM64 FIX: Check if timer has expired (using unsigned arithmetic carefully)
		// If clock < count, subtraction underflows to huge number, which is >= 10000
		if (t >= 10000) {
			// Timer hasn't expired yet, stop processing
			if (is_halt_call && check_timers_count < 10) {
				char buf[256];
				snprintf(buf, sizeof(buf),
					"  CPU Timer[%d] NOT expired: clock=%u count=%u diff=%u (underflow=%s)",
					tmr, (unsigned)calc->z80.clock,
					(unsigned)calc->z80.timers[tmr].count,
					(unsigned)t,
					(calc->z80.clock < calc->z80.timers[tmr].count) ? "YES" : "NO");
				tilem_qt_debug(buf);
			}
			break;
		}

		// Timer has expired, process it
		callback = calc->z80.timers[tmr].callback;
		callbackdata = calc->z80.timers[tmr].callbackdata;

		if (is_halt_call && check_timers_count < 10) {
			char buf[256];
			snprintf(buf, sizeof(buf),
				"  CPU Timer[%d] EXPIRED: clock=%u count=%u diff=%u - calling callback",
				tmr, (unsigned)calc->z80.clock,
				(unsigned)calc->z80.timers[tmr].count, (unsigned)t);
			tilem_qt_debug(buf);
		}

		timer_unset(&calc->z80, tmr);
		timer_set(&calc->z80, tmr, calc->z80.timers[tmr].period,
			  calc->z80.timers[tmr].period, 0, t);

		(*callback)(calc, callbackdata);
		cpu_timers_processed++;
	}

	// Process RT timers - same logic
	int rt_timers_processed = 0;
	while (calc->z80.timer_rt) {
		tmr = calc->z80.timer_rt;
		t = calc->z80.clock - calc->z80.timers[tmr].count;
		if (t >= 10000)
			break;

		callback = calc->z80.timers[tmr].callback;
		callbackdata = calc->z80.timers[tmr].callbackdata;

		// ARM64 DEBUG (Oct 10, 2025): Log timer period before reschedule
		dword timer_period = calc->z80.timers[tmr].period;
		if (is_halt_call && check_timers_count < 10) {
			char buf[256];
			snprintf(buf, sizeof(buf),
				"  RT Timer[%d] EXPIRED: period=%u - about to reschedule",
				tmr, (unsigned)timer_period);
			tilem_qt_debug(buf);
		}

		timer_unset(&calc->z80, tmr);
		timer_set(&calc->z80, tmr, timer_period, timer_period, 1, t);

		if (is_halt_call && check_timers_count < 10 && timer_period == 0) {
			tilem_qt_debug("  *** WARNING: Timer period is 0! Timer will be DISABLED!");
		}

		(*callback)(calc, callbackdata);
		rt_timers_processed++;
	}

	if (is_halt_call && check_timers_count < 10) {
		char buf[256];
		snprintf(buf, sizeof(buf),
			"*** CHECK_TIMERS[%d] EXIT: processed %d CPU timers, %d RT timers, interrupts=0x%02X",
			check_timers_count++, cpu_timers_processed, rt_timers_processed,
			calc->z80.interrupts);
		tilem_qt_debug(buf);
	}
}

static inline void check_breakpoints(TilemCalc* calc, int list, dword addr)
{
	dword masked;
	int bp;
	TilemZ80BreakpointFunc testfunc;
	void* testdata;

	for (bp = list; bp; bp = calc->z80.breakpoints[bp].next) {
		masked = addr & calc->z80.breakpoints[bp].mask;
		if (masked < calc->z80.breakpoints[bp].start
		    || masked > calc->z80.breakpoints[bp].end)
			continue;

		testfunc = calc->z80.breakpoints[bp].testfunc;
		testdata = calc->z80.breakpoints[bp].testdata;

		if (testfunc && !(*testfunc)(calc, addr, testdata))
			continue;

		calc->z80.stop_breakpoint = bp;
		tilem_z80_stop(calc, TILEM_STOP_BREAKPOINT);
	}
}

static inline void check_mem_breakpoints(TilemCalc* calc, int list_l,
					 int list_p, dword addr)
{
	check_breakpoints(calc, list_l, addr);

	if (list_p) {
		addr = (*calc->hw.mem_ltop)(calc, addr);
		check_breakpoints(calc, list_p, addr);
	}
}

static inline byte z80_readb_m1(TilemCalc* calc, dword addr)
{
	byte b;
	addr &= 0xffff;
	b = (*calc->hw.z80_rdmem_m1)(calc, addr);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mx,
			      calc->z80.breakpoint_mpx, addr);
	Rl++;
	return b;
}

static inline byte z80_readb(TilemCalc* calc, dword addr)
{
	byte b;
	addr &= 0xffff;
	b = (*calc->hw.z80_rdmem)(calc, addr);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mr,
			      calc->z80.breakpoint_mpr, addr);
	return b;
}

static inline dword z80_readw(TilemCalc* calc, dword addr)
{
	dword v;
	addr &= 0xffff;
	v = (*calc->hw.z80_rdmem)(calc, addr);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mr,
			      calc->z80.breakpoint_mpr, addr);
	addr = (addr + 1) & 0xffff;
	v |= (*calc->hw.z80_rdmem)(calc, addr) << 8;
	check_mem_breakpoints(calc, calc->z80.breakpoint_mr,
			      calc->z80.breakpoint_mpr, addr);
	return v;
}

static inline byte z80_input(TilemCalc* calc, dword addr)
{
	byte b;
	addr &= 0xffff;
	check_timers(calc);
	b = (*calc->hw.z80_in)(calc, addr);
	check_breakpoints(calc, calc->z80.breakpoint_pr, addr);
	return b;
}

static inline void z80_writeb(TilemCalc* calc, dword addr, byte value)
{
	addr &= 0xffff;
	(*calc->hw.z80_wrmem)(calc, addr, value);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mw,
			      calc->z80.breakpoint_mpw, addr);
	calc->z80.lastwrite = calc->z80.clock;
}

static inline void z80_writew(TilemCalc* calc, dword addr, word value)
{
	addr &= 0xffff;
	(*calc->hw.z80_wrmem)(calc, addr, value);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mw,
			      calc->z80.breakpoint_mpw, addr);
	addr = (addr + 1) & 0xffff;
	value >>= 8;
	(*calc->hw.z80_wrmem)(calc, addr, value);
	check_mem_breakpoints(calc, calc->z80.breakpoint_mw,
			      calc->z80.breakpoint_mpw, addr);
	calc->z80.lastwrite = calc->z80.clock;
}

static inline void z80_output(TilemCalc* calc, dword addr, byte value)
{
	addr &= 0xffff;
	check_timers(calc);

	// ARM64 DEBUG (Oct 9, 16:00 UTC): AGGRESSIVE OUT LOGGING
	// Log EVERY Z80 OUT instruction at CPU level (first 200 operations)
	static int out_instruction_count = 0;
	if (out_instruction_count++ < 200) {
		char buf[256];
		snprintf(buf, sizeof(buf), "*** Z80 OUT [%d]: port=0x%02X value=0x%02X PC=0x%04X",
		        out_instruction_count, (unsigned)(addr & 0xFF), value, calc->z80.r.pc.w.l);
		tilem_qt_debug(buf);

		// Special attention to PORT3 (0x03) and PORT4 (0x04) writes
		if ((addr & 0x1F) == 0x03) {
			byte old_port3 = calc->hwregs[1];  // Read hwregs[1] BEFORE write
			snprintf(buf, sizeof(buf), "*** Z80 OUT TO PORT3! old_hwregs[1]=0x%02X new_value=0x%02X",
			        old_port3, value);
			tilem_qt_debug(buf);
		}
		if ((addr & 0x1F) == 0x04) {
			byte old_port4 = calc->hwregs[2];  // Read hwregs[2] BEFORE write
			snprintf(buf, sizeof(buf), "*** Z80 OUT TO PORT4! old_hwregs[2]=0x%02X new_value=0x%02X",
			        old_port4, value);
			tilem_qt_debug(buf);
		}
	}

	(*calc->hw.z80_out)(calc, addr, value);
	check_breakpoints(calc, calc->z80.breakpoint_pw, addr);
}

